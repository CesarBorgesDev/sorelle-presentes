# Copie para server/.env no servidor:
#   cp deploy/aapanel/env.production.example server/.env
#
# O install.sh preenche DATABASE_URL, JWT_SECRET e URLs se server/.env não existir.
# Depois edite senhas, domínio e integrações (Cielo, Correios, PIX).

# PostgreSQL (aaPanel — use o usuário/senha criados no painel ou pelo install.sh)
DATABASE_URL=postgresql://sorelle:postgres@127.0.0.1:5432/sorelle

# JWT
JWT_SECRET=GERE_UMA_CHAVE_LONGA_ALEATORIA
JWT_EXPIRES_IN=7d

# Servidor
PORT=3001
CORS_ORIGIN=https://sorellepresentes.com.br
FRONTEND_URL=https://sorellepresentes.com.br
APP_PUBLIC_URL=https://sorellepresentes.com.br

# Admin inicial (criado no seed — altere a senha antes do deploy)
ADMIN_EMAIL=admin@sorelle.com.br
ADMIN_PASSWORD=admin123

# Cielo Checkout
CIELO_MERCHANT_ID=
CIELO_SOFT_DESCRIPTOR=SORELLE
CIELO_MAX_INSTALLMENTS=12
CIELO_CHECKOUT_URL=https://cieloecommerce.cielo.com.br/api/public/v1/orders/

# Checkout — pix | cartao_credito | boleto | test
CHECKOUT_PAYMENT_METHOD=pix
PIX_KEY=
PIX_HOLDER_NAME=Sorelle Presentes

# Correios — frete (CalcPrecoPrazo)
CORREIOS_ORIGIN_ZIP=01310100
CORREIOS_COMPANY_CODE=
CORREIOS_PASSWORD=
# Produção: off (só Correios) | auto | estimate
CORREIOS_FALLBACK=off
CORREIOS_DEFAULT_WEIGHT_KG=0.3
CORREIOS_DEFAULT_LENGTH_CM=20
CORREIOS_DEFAULT_WIDTH_CM=15
CORREIOS_DEFAULT_HEIGHT_CM=10

# Transportadora (frete manual — Admin → Configurações → Frete)
SHIPPING_CARRIER_ENABLED=false
SHIPPING_CARRIER_NAME=Transportadora
SHIPPING_CARRIER_PRICE=
SHIPPING_CARRIER_DEADLINE_DAYS=10
