# Gerado automaticamente por install-docker.sh — ou copie manualmente para server/.env
# Senhas com @ na DATABASE_URL devem usar URL-encoding (%40)

DATABASE_URL=postgresql://postgres:SENHA_URL_ENCODED@127.0.0.1:5432/sorelle

JWT_SECRET=GERE_UMA_CHAVE_LONGA_ALEATORIA
JWT_EXPIRES_IN=7d

PORT=3001
HOST=0.0.0.0
NODE_ENV=production
DOMAIN=sorellepresentes.com.br

CORS_ORIGIN=https://sorellepresentes.com.br
FRONTEND_URL=https://sorellepresentes.com.br
APP_PUBLIC_URL=https://api.sorellepresentes.com.br

ADMIN_EMAIL=admin@sorelle.com.br
ADMIN_PASSWORD=ALTERE_SENHA_ADMIN

CIELO_MERCHANT_ID=
CIELO_SOFT_DESCRIPTOR=SORELLE
CIELO_MAX_INSTALLMENTS=12
