# IP público ou domínio da loja (Nginx server_name)
DOMAIN=sorellepresentes.com.br

# Subdomínio da API (auto: api.${DOMAIN} se omitido e DOMAIN não for IP)
API_DOMAIN=api.sorellepresentes.com.br

# Nome do site no aaPanel (arquivo vhost: /www/server/panel/vhost/nginx/sorelle-presentes.conf)
SITE_NAME=sorelle-presentes

POSTGRES_PASSWORD=SENHA_FORTE

# Código-fonte clonado do GitHub
APP_DIR=/home/deploy/sorelle-presentes

# Pasta pública do site (Nginx root / aaPanel → Website → root)
SITE_ROOT=/home/deploy/sorelle-presentes/dist

REPO_URL=https://github.com/CesarBorgesDev/sorelle-presentes.git

# http para IP | https para domínio (auto se omitido)
# SITE_SCHEME=http
