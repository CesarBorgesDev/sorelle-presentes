# Copie para server/.env e ajuste os valores.
# Senhas com @ na DATABASE_URL devem usar URL-encoding (%40).

# --- Banco de dados (obrigatório) ---
# Local: localhost | VPS host: 127.0.0.1 | Docker: trocado para "db" pelo entrypoint
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/sorelle

# --- Autenticação (obrigatório) ---
JWT_SECRET=GERE_UMA_CHAVE_LONGA_ALEATORIA_COM_PELO_MENOS_32_CARACTERES
JWT_EXPIRES_IN=7d

# --- Servidor ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- Domínio (CORS automático para *.seudominio.com.br) ---
DOMAIN=sorellepresentes.com.br

# --- URLs públicas (CORS e callbacks de pagamento) ---
# Produção — loja no domínio principal, API no subdomínio api.:
# CORS_ORIGIN=https://sorellepresentes.com.br
# FRONTEND_URL=https://sorellepresentes.com.br
# APP_PUBLIC_URL=https://api.sorellepresentes.com.br
#
# Produção — mesmo domínio (/api via Nginx):
# CORS_ORIGIN=https://sorellepresentes.com.br
# FRONTEND_URL=https://sorellepresentes.com.br
# APP_PUBLIC_URL=https://sorellepresentes.com.br
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000

# --- Seed do admin (npm run db:seed) ---
ADMIN_EMAIL=admin@sorelle.com.br
ADMIN_PASSWORD=admin123

# --- Checkout / pagamento ---
CHECKOUT_PAYMENT_METHOD=test
PIX_KEY=
PIX_HOLDER_NAME=Sorelle Presentes

# --- Cielo — Checkout Cielo (redirecionamento + Controle Transacional) ---
CIELO_MERCHANT_ID=
CIELO_CLIENT_ID=
CIELO_CLIENT_SECRET=
CIELO_ENVIRONMENT=production
CIELO_NOTIFICATION_METHOD=post
CIELO_SOFT_DESCRIPTOR=SORELLE
CIELO_MAX_INSTALLMENTS=12

# --- SiPag — IPG Online (e-commerce Sicoob/Fiserv) ---
SIPAG_STORE_ID=
SIPAG_USER_ID=
SIPAG_USER_PASSWORD=
SIPAG_CERT_PASSWORD=
# Conteúdo PEM ou caminhos dos arquivos:
SIPAG_CERT_PEM=
SIPAG_CERT_KEY=
# SIPAG_CERT_PEM_PATH=
# SIPAG_CERT_KEY_PATH=
SIPAG_ENVIRONMENT=test
SIPAG_SOFT_DESCRIPTOR=SORELLE
PAYMENT_GATEWAY=cielo

# --- Mercado Pago — Checkout Pro ---
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_ENVIRONMENT=test
# MERCADO_PAGO_FRONTEND_URL=
# MERCADO_PAGO_BACKEND_PUBLIC_URL=

# --- Frete — Correios ---
CORREIOS_ORIGIN_ZIP=01310100
CORREIOS_COMPANY_CODE=
CORREIOS_PASSWORD=
CORREIOS_FALLBACK=auto
CORREIOS_DEFAULT_WEIGHT_KG=0.3
CORREIOS_DEFAULT_LENGTH_CM=20
CORREIOS_DEFAULT_WIDTH_CM=15
CORREIOS_DEFAULT_HEIGHT_CM=10

# --- Frete — transportadora fixa ---
SHIPPING_CARRIER_ENABLED=false
SHIPPING_CARRIER_NAME=Transportadora
SHIPPING_CARRIER_PRICE=
SHIPPING_CARRIER_DEADLINE_DAYS=10

# --- Geração de imagens (opcional) ---
STABLE_HORDE_API_KEY=
