# Copie para .env ou .env.local na raiz do projeto (frontend Vite).
# Em desenvolvimento, o proxy do Vite encaminha /api para http://localhost:3001.

# URL base da API. Deixe /api para usar o proxy (dev) ou o Nginx (produção).
VITE_API_URL=/api

# --- Legado Base44 (opcional — não necessário com a API PostgreSQL local) ---
# VITE_BASE44_APP_ID=
# VITE_BASE44_APP_BASE_URL=
# VITE_BASE44_FUNCTIONS_VERSION=

# Build: importações legadas do SDK Base44 (@/integrations, @/entities, etc.)
# BASE44_LEGACY_SDK_IMPORTS=true
